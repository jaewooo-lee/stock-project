# Google Gemini API Key for News Summarization
GEMINI_API_KEY=your_gemini_api_key_here

# Kakao REST API Configurations (for KakaoTalk notifications)
KAKAO_REST_API_KEY=your_kakao_rest_api_key_here
KAKAO_REDIRECT_URI=http://localhost:8000/api/kakao/callback
KAKAO_REFRESH_TOKEN=your_kakao_refresh_token_here

# Application Configurations
BASE_URL=http://localhost
DATABASE_URL=sqlite:///./stock_tracker.db
REPORTS_DIR=./reports
CLEANUP_DAYS=90
